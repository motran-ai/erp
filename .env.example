# =============================================================================
# Motran ERP (Midday) — Self-hosted environment variables
# Copy to .env and fill in values: cp .env.example .env && chmod 600 .env
# =============================================================================

# -- Core URLs ----------------------------------------------------------------
NEXT_PUBLIC_URL=https://erp.motran.ai
NEXT_PUBLIC_API_URL=https://erp.motran.ai/api/engine
MIDDAY_DASHBOARD_URL=https://erp.motran.ai
MIDDAY_API_URL=http://erp-api:8080

# -- Supabase (Cloud free tier) -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_ID=xxxxx
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SECRET_KEY=eyJ...
SUPABASE_JWT_SECRET=

# -- Database (Supabase Postgres pooler) --------------------------------------
# IMPORTANT: Use the pooler URLs (not db.xxxxx.supabase.co) — the direct host
# resolves to IPv6 only, which Docker containers cannot reach.
# Find your pooler region in Supabase Dashboard → Settings → Database → Connection string.
DATABASE_PRIMARY_URL=postgresql://postgres.xxxxx:password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_PRIMARY_POOLER_URL=postgresql://postgres.xxxxx:password@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_SESSION_POOLER=postgresql://postgres.xxxxx:password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# -- Redis (Upstash) ----------------------------------------------------------
REDIS_URL=rediss://default:xxxxx@eu1-xxxxx.upstash.io:6379
REDIS_QUEUE_URL=rediss://default:xxxxx@eu1-xxxxx.upstash.io:6379

# -- Encryption keys ----------------------------------------------------------
# Generate with: openssl rand -hex 32
MIDDAY_ENCRYPTION_KEY=
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
FILE_KEY_SECRET=
INVOICE_JWT_SECRET=
WEBHOOK_SECRET_KEY=

# -- Email (Resend) -----------------------------------------------------------
RESEND_API_KEY=re_xxxxx

# -- Banking (GoCardless — EU bank connections) --------------------------------
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# -- AI (OpenAI) --------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxx

# -- File Storage (Supabase Storage or R2) -------------------------------------
# Using Supabase Storage (included in free tier) — no extra config needed.
# For R2, uncomment below:
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# -- CORS / Security ----------------------------------------------------------
ALLOWED_API_ORIGINS=https://erp.motran.ai

# -- Optional: Stripe (invoice payments) --------------------------------------
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_CONNECT_CLIENT_ID=
# STRIPE_CONNECT_WEBHOOK_SECRET=

# -- Optional: Sentry (error tracking) ----------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# -- Optional: Trigger.dev (background jobs) ----------------------------------
# TRIGGER_SECRET_KEY=
# TRIGGER_PROJECT_ID=

# -- Optional: Slack integration ----------------------------------------------
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_OAUTH_REDIRECT_URL=https://erp.motran.ai/api/engine/apps/slack/oauth-callback
# SLACK_SIGNING_SECRET=
# SLACK_STATE_SECRET=

# -- Runtime -------------------------------------------------------------------
NODE_ENV=production
PORT=3000
